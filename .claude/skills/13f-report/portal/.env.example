# ── Local development (.env.local, never committed) ───────────────────────────
# These VITE_ variables are only used in `npm run dev`.
# In production the Vercel serverless proxy calls FMP/Polygon directly,
# so these keys are NEVER bundled into the production JS.

VITE_FMP_API_KEY=your_fmp_key_here
VITE_POLYGON_API_KEY=your_polygon_key_here      # optional


# ── Production (Vercel dashboard only) ────────────────────────────────────────
# Go to: Vercel project → Settings → Environment Variables
# Add these WITHOUT the VITE_ prefix — they live server-side only.
#
#   FMP_API_KEY        = your_fmp_key_here
#   POLYGON_API_KEY    = your_polygon_key_here   (optional)
